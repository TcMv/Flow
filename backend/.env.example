# Flow Backend — Environment Configuration
# Copy this file to .env and adjust as needed.

# Database
DATABASE_URL=sqlite+aiosqlite:///./flow_dev.db
# For PostgreSQL (production / RDS):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/flow

# Application
APP_NAME=Flow
APP_VERSION=0.1.0
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-string

# LLM Key Encryption — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ENCRYPTION_KEY=

# LLM Env Var Fallback — set your API key here to skip DB key setup
# Provider: openai (default), anthropic, or custom
# Model: gpt-4o-mini, claude-sonnet-4, etc.
# FLOW_API_KEY=sk-...
# FLOW_LLM_PROVIDER=openai
# FLOW_LLM_MODEL=gpt-4o-mini
